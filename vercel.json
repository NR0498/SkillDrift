{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/skills/:path*", "destination": "/api" },
    { "source": "/search", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/docs", "destination": "/api" },
    { "source": "/openapi.json", "destination": "/api" }
  ]
}
