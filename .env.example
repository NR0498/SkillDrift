ENVIRONMENT=development
LOG_LEVEL=INFO

# Local SQLite defaults. Set DATABASE_URL to a Neon/PostgreSQL URL in production.
DATABASE_URL=
JOBS_DB_PATH=data/jobs.db
TRENDS_DB_PATH=data/trends.db

REMOTEOK_URL=https://remoteok.com/api
REMOTEOK_USER_AGENT=SkillDrift/1.0 (portfolio project; contact: you@example.com)

SOLR_URL=http://localhost:8983/solr/jobs_core
SOLR_TIMEOUT_SECONDS=10

# Use "*" locally. Set exact frontend origins as a comma-separated list in production.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LocalStack defaults. For AWS, remove AWS_ENDPOINT_URL and provide real credentials/role.
S3_BUCKET=skilldrift-output
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

